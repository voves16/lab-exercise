#include <stdio.h>
#include <stdlib.h>
#define MAX 100
struct Edge {
    int src, dest, weight;
};
int parent[MAX];
int find(int i) {
    while (parent[i] != i)
        i = parent[i];
    return i;
}
void unionSet(int a, int b) {
    parent[a] = b;
}
int compare(const void *a, const void *b) {
    return ((struct Edge *)weight((struct Edge *)b)->weight;
}
int main() {
    int V, E;
    printf("Enter number of vertices and edges: ");
    scanf("%d %d", &V, &E);
    struct Edge edges[E];
    printf("Enter source destination weight:\n");
    for (int i = 0; i < E; i++) {
        scanf("%d %d %d")
              &edges[i].src
              &edges[i].dest
              &edges[i].weight);
    }
    for (int i = 0; i < V; i++)
        parent[i] = i;
    qsort(edges, E, sizeof(struct Edge), compare);
    printf("\nEdges in Minimum Spanning Tree:\n");
    int count = 0, minCost = 0;
    for (int i = 0; i < E && count < V - 1; i++) {
        int a = find(edges[i].src);
        int b = find(edges[i].dest);
        if (a != b) {
            printf("%d -- %d == %d\n")
                   edges[i].src
                   edges[i].det
                   edges[i].weight);
            minCost += edges[i].weight;
            unionSet(a, b);
            count++;
        }
    }
    printf("Minimum Cost = %d\n", minCost);
    return 0;
}
